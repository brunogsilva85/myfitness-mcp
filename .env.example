# MyFitnessPal MCP Server - Environment Variables
# Copy this file to .env and fill in your values

# Required: MyFitnessPal session cookies (choose one source)
# Option 1 (recommended): Firefox profile directory with a logged-in
# myfitnesspal.com session, mounted read-only into the container.
# In Docker this defaults to /profile.
MFP_FIREFOX_PROFILE_DIR=/profile

# Option 2: JSON cookies file ({"cookies": {name: value}} or {name: value}),
# same format as AdamWalt's ~/.mfp_mcp/cookies.json
# MFP_COOKIES_FILE=/cookies.json

# Optional - HTTP transport settings (Docker image defaults shown)
# MCP_TRANSPORT=streamable-http   # "stdio" (default outside Docker) or "streamable-http"
# MCP_HOST=0.0.0.0
# MCP_PORT=8000
# MCP_ALLOWED_HOSTS=mfp.example.com,mfp.example.com:443

# Optional - OAuth for remote MCP connectors (Claude, ChatGPT).
# Omit both to run unauthenticated (LAN-only deployments).
# MCP_OAUTH_PASSCODE=<a long random secret>  # python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# MCP_RESOURCE_URL=https://mfp.example.com
